# Copy this file to .env.local and fill in deployment-specific values.
# Never commit .env.local or provider tokens.

# Required --------------------------------------------------------------------
# PostgreSQL connection string.
DATABASE_URL=

# optional = local single-user mode; required = hosted/team mode with login.
AIKO_AUTH_MODE=optional

# Must match the URL you open in the browser.
NEXTAUTH_URL=http://localhost:3001

# Generate with: openssl rand -base64 32
# Set both for compatibility with NextAuth/Auth.js naming.
AUTH_SECRET=
NEXTAUTH_SECRET=

# Local AI --------------------------------------------------------------------
# Used when Ollama is selected as the local brain.
OLLAMA_BASE_URL=http://localhost:11434

# Web Operator ----------------------------------------------------------------
# true = hidden browser; false = visible browser for manual takeover.
WEB_OPERATOR_HEADLESS=true
BROWSER_HEADLESS=true

# Optional API providers -------------------------------------------------------
# Leave blank unless you are using API-key provider connections.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Optional ChatGPT / Codex OAuth ----------------------------------------------
# Redirect URI: {NEXTAUTH_URL}/api/providers/oauth/chatgpt/callback
OPENAI_OAUTH_CLIENT_ID=
OPENAI_OAUTH_AUTH_URL=
OPENAI_OAUTH_TOKEN_URL=
OPENAI_OAUTH_REDIRECT_URI=
OPENAI_OAUTH_CLIENT_SECRET=

# Optional ChatGPT / Codex Local Auth -----------------------------------------
# Usually leave blank. AÏKO defaults to ~/.codex/auth.json when Codex is logged in.
CODEX_HOME=
OPENAI_CODEX_AUTH_FILE=
CODEX_MODEL=codex-cli-default

# Optional Claude OAuth / Claude Code -----------------------------------------
# Redirect URI: {NEXTAUTH_URL}/api/providers/oauth/claude/callback
CLAUDE_OAUTH_CLIENT_ID=
CLAUDE_OAUTH_AUTH_URL=
CLAUDE_OAUTH_TOKEN_URL=
CLAUDE_OAUTH_CLIENT_SECRET=
CLAUDE_CODE_OAUTH_TOKEN=

# Optional Google login identity ----------------------------------------------
# Google login identifies users; it does not connect ChatGPT or Claude.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Storage ---------------------------------------------------------------------
# Leave blank to use app defaults. Paths should be writable by the app process.
GENERATED_FILES_DIR=
SCREENSHOTS_DIR=

# Legacy screenshot path used by the current browser screenshot routes.
SCREENSHOT_PATH=
