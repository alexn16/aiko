# Copy to .env.local and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose sets this automatically; for local dev use your own Postgres URL
DATABASE_URL=postgresql://aiko:aiko@localhost:5432/aiko

# ── Authentication (NextAuth) ─────────────────────────────────────────────────
# Generate a random secret:  openssl rand -base64 32
# AUTH_SECRET and NEXTAUTH_SECRET are interchangeable — set one or both.
AUTH_SECRET=
NEXTAUTH_SECRET=
# Must match the URL you open in the browser. Use 3001 if 3000 is taken.
NEXTAUTH_URL=http://localhost:3001

# ── Google OAuth (Sign in with Google — user identity only) ───────────────────
#
# Creates an AÏKO user account. Does NOT connect ChatGPT or Claude.
# Each AI brain must be connected separately in /connect-ai.
#
# Setup steps:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create OAuth 2.0 Client ID  →  Web application
#   3. Authorized JavaScript origins:
#        http://localhost:3001
#   4. Authorized redirect URIs:
#        http://localhost:3001/api/auth/callback/google
#   5. Copy Client ID and Client Secret below
#   6. Restart the dev server after saving .env.local
#
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI subscription account connections (optional) ───────────────────────────
# These let users connect their ChatGPT or Claude account via OAuth.
# Leave blank to use API key connections only (the usual path).
# Google login does NOT grant access to these — they require their own OAuth apps.

# ChatGPT / Codex OAuth  (requires registering an app with OpenAI)
# Redirect URI to register: {NEXTAUTH_URL}/api/providers/oauth/chatgpt/callback
OPENAI_OAUTH_CLIENT_ID=
OPENAI_OAUTH_CLIENT_SECRET=
OPENAI_OAUTH_AUTH_URL=
OPENAI_OAUTH_TOKEN_URL=
OPENAI_OAUTH_SCOPE=openid profile email
OPENAI_OAUTH_DEFAULT_MODEL=gpt-4o

# Claude account OAuth  (requires registering an app with Anthropic)
# Redirect URI to register: {NEXTAUTH_URL}/api/providers/oauth/claude/callback
CLAUDE_OAUTH_CLIENT_ID=
CLAUDE_OAUTH_CLIENT_SECRET=
CLAUDE_OAUTH_AUTH_URL=
CLAUDE_OAUTH_TOKEN_URL=
CLAUDE_OAUTH_SCOPE=openid profile email
CLAUDE_OAUTH_DEFAULT_MODEL=claude-opus-4-5

# ── Browser ───────────────────────────────────────────────────────────────────
# Set to 'false' during development to see the browser window
BROWSER_HEADLESS=true

# Screenshot storage (local path inside container)
SCREENSHOT_PATH=./screenshots
