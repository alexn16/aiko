# Copy to .env.local and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose sets this automatically
DATABASE_URL=postgresql://aiko:aiko@localhost:5432/aiko

# ── Authentication (NextAuth) ─────────────────────────────────────────────────
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (Sign in with Google — identifies AÏKO users)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI subscription account connections ──────────────────────────────────────
# These allow users to connect their ChatGPT and Claude accounts.
# Leave blank to use API key connections only.
# Google login does NOT grant access to these — they require their own OAuth.

# ChatGPT / Codex OAuth
# Requires registering an OAuth app with OpenAI (when available)
OPENAI_OAUTH_CLIENT_ID=
OPENAI_OAUTH_CLIENT_SECRET=
OPENAI_OAUTH_AUTH_URL=
OPENAI_OAUTH_TOKEN_URL=
OPENAI_OAUTH_SCOPE=openid profile email
OPENAI_OAUTH_DEFAULT_MODEL=gpt-4o
# Redirect URI (set in your OAuth app): {NEXTAUTH_URL}/api/providers/oauth/chatgpt/callback

# Claude account OAuth
# Requires registering an OAuth app with Anthropic (when available)
CLAUDE_OAUTH_CLIENT_ID=
CLAUDE_OAUTH_CLIENT_SECRET=
CLAUDE_OAUTH_AUTH_URL=
CLAUDE_OAUTH_TOKEN_URL=
CLAUDE_OAUTH_SCOPE=openid profile email
CLAUDE_OAUTH_DEFAULT_MODEL=claude-opus-4-5
# Redirect URI (set in your OAuth app): {NEXTAUTH_URL}/api/providers/oauth/claude/callback

# ── Browser ───────────────────────────────────────────────────────────────────
# Set to 'false' during development to see the browser
BROWSER_HEADLESS=true

# Screenshot storage (local path inside container)
SCREENSHOT_PATH=./screenshots
