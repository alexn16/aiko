# Copy to .env.local and fill in your values

# Database (Docker Compose sets this automatically)
DATABASE_URL=postgresql://aiko:aiko@localhost:5432/aiko

# Auth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Browser (set to 'false' during development to see the browser)
BROWSER_HEADLESS=true

# Screenshot storage (local path inside container)
SCREENSHOT_PATH=./screenshots
